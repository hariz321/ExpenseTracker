<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    <title>View Expense</title>
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container">

            <a class="navbar-brand" href="/">Expense Tracker</a>

            <div class="ms-auto">

                <a class="nav-link text-white d-inline me-3" href="/">Home</a>

                <a class="nav-link text-white d-inline me-3" href="/expenses">View Expenses</a>

                <a class="nav-link text-white d-inline" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">
                        <h4 class="mb-0">Expense Details</h4>
                    </div>

                    <div class="card-body p-4">

                        <div class="mb-3">
                            <strong>Expense ID:</strong>
                            <span><%= expense.id %></span>
                        </div>

                        <div class="mb-3">
                            <strong>Title:</strong>
                            <span><%= expense.title %></span>
                        </div>

                        <div class="mb-3">
                            <strong>Amount:</strong>
                            <span>
                                $<%= Number(expense.amount).toFixed(2) %>
                            </span>
                        </div>

                        <div class="mb-4">
                            <strong>Category:</strong>
                            <span class="badge text-bg-secondary"> <%= expense.category %></span>
                        </div>

                        <a href="/editExpense/<%= expense.id %>" class="btn btn-warning me-2">Edit</a>

                        <a href="/expenses" class="btn btn-outline-secondary" >Back to Expenses</a>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>