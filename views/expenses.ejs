<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    <title>Manage Expenses</title>
</head>

<body class="bg-light">
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container">

            <a class="navbar-brand" href="/">Expense Tracker</a>

            <div class="ms-auto">
                <a class="nav-link text-white d-inline me-3" href="/">Home</a>

                <a class="nav-link text-white d-inline me-3" href="/addExpense">Add Expense</a>

                <a class="nav-link text-white d-inline" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h1 class="fw-bold mb-1">Manage Expenses</h1>

                <p class="text-muted mb-0">View and manage your recorded expenses.</p>
            </div>

            <a href="/addExpense" class="btn btn-success">Add Expense</a>

        </div>

        <!-- ===== Spending Summary ===== --> 
        <% if (expenses.length > 0) { %>

            <!-- Total Spent card -->
            <div class="card border-0 shadow-sm mb-4 text-white"
                style="background: linear-gradient(120deg, #7b2ff7, #9f44d3); border-radius: 1rem;">
                <div class="card-body p-4">

                    <p class="text-uppercase fw-bold mb-1" style="letter-spacing: 2px; font-size: 0.8rem;">
                        Total Spent
                    </p>

                    <h1 class="display-5 fw-bold mb-1">
                        $<%= totalAmount.toFixed(2) %>
                    </h1>

                    <p class="mb-0" style="opacity: 0.85;">
                        across <%= expenseCount %> expense<%= expenseCount === 1 ? '' : 's' %>
                    </p>

                </div>
            </div>

            <!-- By Category card -->
            <div class="card shadow-sm mb-4" style="border-radius: 1rem;">
                <div class="card-body p-4">

                    <p class="text-uppercase fw-bold text-muted mb-3"
                        style="letter-spacing: 2px; font-size: 0.8rem;">
                        By Category
                    </p>

                    <%
                        const barColors = ['#14b8a6', '#8b5cf6', '#3b82f6', '#f59e0b', '#ef4444', '#ec4899', '#6b7280'];
                        const topCategories = categorySummary.slice(0, 4);
                        const remaining = categorySummary.length - topCategories.length;
                        const maxTotal = categorySummary.length > 0 ? categorySummary[0].total : 0;
                    %>

                    <% topCategories.forEach(function(item, index) { %>

                        <div class="d-flex align-items-center mb-3">

                            <div style="width: 110px;" class="flex-shrink-0">
                                <%= item.category %>
                            </div>

                            <div class="flex-grow-1 mx-3">
                                <div class="progress" style="height: 10px; border-radius: 5px;">
                                    <div class="progress-bar"
                                        style="width: <%= maxTotal > 0 ? Math.round((item.total / maxTotal) * 100) : 0 %>%;
                                               background-color: <%= barColors[index % barColors.length] %>;
                                               border-radius: 5px;">
                                    </div>
                                </div>
                            </div>

                            <div style="width: 90px;" class="text-end fw-semibold flex-shrink-0">
                                $<%= item.total.toFixed(2) %>
                            </div>

                        </div>

                    <% }); %>

                    <% if (remaining > 0) { %>
                        <p class="text-muted mb-0" style="font-size: 0.85rem;">
                            + <%= remaining %> more categor<%= remaining === 1 ? 'y' : 'ies' %> in the list below
                        </p>
                    <% } %>

                </div>
            </div>

        <% } %>
        <!-- ===== End Spending Summary ===== -->

        <div class="card shadow-sm">
            <div class="card-body">
                <% if (expenses.length===0) { %>
                    <div class="text-center py-5">

                        <h4>No expenses found</h4>
                        <p class="text-muted">Add your first expense to get started.</p>

                        <a href="/addExpense" class="btn btn-primary">Add Expense</a>

                    </div>

                    <% } else { %>

                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Title</th>
                                        <th>Amount</th>
                                        <th>Category</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>

                                <tbody>

                                    <% expenses.forEach(function(expense) { %>
                                        <tr>

                                            <td><%= expense.id %></td>
                                            <td><%= expense.title %></td>
                                            <td> $<%= Number(expense.amount).toFixed(2) %></td>

                                            <td>
                                                <span class="badge text-bg-secondary">
                                                    <%= expense.category %>
                                                </span>
                                            </td>

                                            <td>
                                                <% if (expense.expense_date) { %>
                                                    <%= new Date(expense.expense_date).toLocaleDateString( 'en-SG' , {
                                                        day: '2-digit' , month: '2-digit' , year: 'numeric' } ) %>
                                                        <% } else { %>
                                                            <span class="text-muted">No date</span>
                                                            <% } %>
                                            </td>
                                            <td>

                                                <a href="/expenses/<%= expense.id %>"
                                                    class="btn btn-primary btn-sm me-1">View
                                                </a>

                                                <a href="/editExpense/<%= expense.id %>"
                                                    class="btn btn-warning btn-sm me-1">Edit
                                                </a>

                                                <a href="/deleteExpense/<%= expense.id %>" class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Are you sure you want to delete this expense?')">Delete
                                                </a>

                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
            </div>
        </div>

        <div class="mt-4">
            <a href="/" class="btn btn-outline-secondary">Back to Dashboard</a>
        </div>
    </main>
</body>
</html>